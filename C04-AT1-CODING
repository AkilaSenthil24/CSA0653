//Question 2 : Minimum Spanning Tree - Kruskal's Algorithm

edges = [(0,1,2),(0,2,3),(1,2,1),(1,3,4),(2,3,5)]

parent = [0,1,2,3]

def find(x):
    while parent[x] != x:
        x = parent[x]
    return x

cost = 0

for u, v, w in sorted(edges, key=lambda x: x[2]):
    if find(u) != find(v):
        cost += w
        parent[find(u)] = find(v)

print("MST Cost =", cost)
