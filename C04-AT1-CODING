//Question 1 : Minimum Spanning Tree - Prim's Algorithm

n = int(input())   
graph = []
for i in range(n):
    graph.append(list(map(int, input().split())))
selected = [False] * n
selected[0] = True
cost = 0
for _ in range(n - 1):
    minimum = 999
    x = y = 0
    for i in range(n):
        if selected[i]:
            for j in range(n):
                if not selected[j] and graph[i][j]:
                    if graph[i][j] < minimum:
                        minimum = graph[i][j]
                        x, y = i, j
    print(x, "-", y, ":", graph[x][y])
    cost += graph[x][y]
    selected[y] = True
print("Minimum Cost =", cost)
