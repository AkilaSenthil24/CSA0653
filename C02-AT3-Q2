def string_match(text, pattern):
    n, m = len(text), len(pattern)

    for i in range(n - m + 1):
        j = 0

        while j < m and text[i + j] == pattern[j]:
            j += 1

        if j == m:
            return i

    return -1


text = input("Enter text: ")
pattern = input("Enter pattern: ")

result = string_match(text, pattern)

print("Output:", result)

